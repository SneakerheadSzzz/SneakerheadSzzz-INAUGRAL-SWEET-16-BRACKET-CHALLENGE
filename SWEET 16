// DATA
// ═══════════════════════════════
const SK = 'shz_b26';
const APASS = 'ZNK2026'; // Change before going live!

function load(){try{return JSON.parse(localStorage.getItem(SK))||def();}catch(e){return def();}}
function save(d){localStorage.setItem(SK,JSON.stringify(d));}

function def(){
  return {
    pot:0,
    teams:{
      east:   [{s:1,n:'TBD'},{s:8,n:'TBD'},{s:4,n:'TBD'},{s:5,n:'TBD'}],
      west:   [{s:1,n:'TBD'},{s:8,n:'TBD'},{s:4,n:'TBD'},{s:5,n:'TBD'}],
      south:  [{s:1,n:'TBD'},{s:8,n:'TBD'},{s:4,n:'TBD'},{s:5,n:'TBD'}],
      midwest:[{s:1,n:'TBD'},{s:8,n:'TBD'},{s:4,n:'TBD'},{s:5,n:'TBD'}],
    },
    results:{
      east_g1:null,east_g2:null,west_g1:null,west_g2:null,
      south_g1:null,south_g2:null,midwest_g1:null,midwest_g2:null,
      e8_east:null,e8_west:null,e8_south:null,e8_midwest:null,
      ff_1:null,ff_2:null,champion:null
    },
    entries:[]
  };
}

let D = load();

// ═══════════════════════════════
// BRACKET RENDERING
// ═══════════════════════════════

function radioBlock(gameKey, t1, t2, lbl){
  return `
    <div class="matchup-block">
      <div class="matchup-lbl">${lbl}</div>
      <div class="team-options">
        <label class="team-radio" id="tr_${gameKey}_0" onclick="pickTeam('${gameKey}',0)">
          <input type="radio" name="${gameKey}" value="${t1.n}">
          <div class="shz-dot"><span class="shz-dot-s">S</span></div>
          <span class="team-nm">${t1.n}</span>
          <span class="seed-tag">SEED ${t1.s}</span>
        </label>
        <div class="vs-row"><span>VS</span></div>
        <label class="team-radio" id="tr_${gameKey}_1" onclick="pickTeam('${gameKey}',1)">
          <input type="radio" name="${gameKey}" value="${t2.n}">
          <div class="shz-dot"><span class="shz-dot-s">S</span></div>
          <span class="team-nm">${t2.n}</span>
          <span class="seed-tag">SEED ${t2.s}</span>
        </label>
      </div>
    </div>`;
}

function pickTeam(gameKey, idx){
  document.getElementById(`tr_${gameKey}_0`).classList.toggle('picked', idx===0);
  document.getElementById(`tr_${gameKey}_1`).classList.toggle('picked', idx===1);
  document.querySelectorAll(`input[name="${gameKey}"]`)[idx].checked = true;
}

function renderRegion(region, containerId){
  const t = D.teams[region];
  document.getElementById(containerId).innerHTML =
    radioBlock(`${region}_g1`, t[0], t[1], 'GAME 1') +
    radioBlock(`${region}_g2`, t[2], t[3], 'GAME 2');
}

function renderE8(){
  const regions = ['east','west','south','midwest'];
  let html = '';
  regions.forEach(r => {
    const all = D.teams[r];
    html += `
      <div class="matchup-block">
        <div class="matchup-lbl">ELITE 8 — ${r.toUpperCase()}</div>
        <div class="team-options">`;
    all.forEach((t,i) => {
      html += `
          <label class="team-radio" id="tr_e8_${r}_${i}" onclick="pickTeamMulti('e8_${r}',${i},'e8_${r}',${all.length})">
            <input type="radio" name="e8_${r}" value="${t.n}">
            <div class="shz-dot"><span class="shz-dot-s">S</span></div>
            <span class="team-nm">${t.n}</span>
            <span class="seed-tag">SEED ${t.s}</span>
          </label>`;
      if(i < all.length-1) html += '<div class="vs-row"><span>VS</span></div>';
    });
    html += `</div></div>`;
  });
  document.getElementById('e8-r').innerHTML = html;
}

function pickTeamMulti(gameKey, idx, prefix, count){
  for(let i=0;i<count;i++){
    const el = document.getElementById(`tr_${prefix}_${i}`);
    if(el) el.classList.toggle('picked', i===idx);
  }
  const radios = document.querySelectorAll(`input[name="${gameKey}"]`);
  if(radios[idx]) radios[idx].checked = true;
}

function renderFF(){
  const allT = [...D.teams.east,...D.teams.west,...D.teams.south,...D.teams.midwest];
  let html = '';
  ['ff_1','ff_2'].forEach((key,gi) => {
    html += `
      <div class="matchup-block">
        <div class="matchup-lbl">FINAL FOUR GAME ${gi+1}</div>
        <div class="team-options">`;
    allT.forEach((t,i) => {
      html += `
          <label class="team-radio" id="tr_${key}_${i}" onclick="pickTeamMulti('${key}',${i},'${key}',${allT.length})">
            <input type="radio" name="${key}" value="${t.n}">
            <div class="shz-dot"><span class="shz-dot-s">S</span></div>
            <span class="team-nm">${t.n}</span>
            <span class="seed-tag">SEED ${t.s}</span>
          </label>`;
      if(i < allT.length-1) html += '<div class="vs-row"><span>VS</span></div>';
    });
    html += `</div></div>`;
  });
  document.getElementById('ff-r').innerHTML = html;
}

function renderChamp(){
  const allT = [...D.teams.east,...D.teams.west,...D.teams.south,...D.teams.midwest];
  let opts = '<option value="">-- Pick Your Champion --</option>';
  allT.forEach(t => opts += `<option value="${t.n}">(${t.s}) ${t.n}</option>`);
  document.getElementById('champ-r').innerHTML = `
    <div class="champ-block">
      <div class="champ-lbl">🏆 WHO WINS IT ALL?</div>
      <select class="champ-sel" id="champPick">${opts}</select>
    </div>`;
}

function renderBracket(){
  renderRegion('east','east-r');
  renderRegion('west','west-r');
  renderRegion('south','south-r');
  renderRegion('midwest','midwest-r');
  renderE8();
  renderFF();
  renderChamp();
}

// ═══════════════════════════════
// GET PICKS
// ═══════════════════════════════

function getRadioVal(name){
  const el = document.querySelector(`input[name="${name}"]:checked`);
  return el ? el.value : '';
}

function getAllPicks(){
  return {
    east_g1:    getRadioVal('east_g1'),
    east_g2:    getRadioVal('east_g2'),
    west_g1:    getRadioVal('west_g1'),
    west_g2:    getRadioVal('west_g2'),
    south_g1:   getRadioVal('south_g1'),
    south_g2:   getRadioVal('south_g2'),
    midwest_g1: getRadioVal('midwest_g1'),
    midwest_g2: getRadioVal('midwest_g2'),
    e8_east:    getRadioVal('e8_east'),
    e8_west:    getRadioVal('e8_west'),
    e8_south:   getRadioVal('e8_south'),
    e8_midwest: getRadioVal('e8_midwest'),
    ff_1:       getRadioVal('ff_1'),
    ff_2:       getRadioVal('ff_2'),
    champion:   document.getElementById('champPick') ? document.getElementById('champPick').value : ''
  };
}

// ═══════════════════════════════
// SUBMIT
// ═══════════════════════════════

function submitBracket(){
  const name  = document.getElementById('eName').value.trim();
  const email = document.getElementById('eEmail').value.trim();
  const order = document.getElementById('eOrder').value.trim();
  const payment = document.getElementById('ePayment').value.trim();
  const count = parseInt(document.getElementById('eCount').value);
  const picks = getAllPicks();

  if(!name||!email||!order){ showAlert('bAlert','err','Please fill in your name, email and order number!'); return; }
  if(!picks.champion){ showAlert('bAlert','err','Please pick your National Champion to submit!'); return; }

  const existing = D.entries.filter(e=>e.email.toLowerCase()===email.toLowerCase());
  const existCount = existing.length;

  // ═══ HARD KILL SWITCH — 12 MAX, NO EXCEPTIONS ═══
  if(existCount >= 12){ 
    showAlert('bAlert','err','🚫 ENTRY CAP REACHED — Maximum of 12 entries per participant. No exceptions.'); 
    return; 
  }
  const remaining = 12 - existCount;
  if(remaining <= 0){
    showAlert('bAlert','err','🚫 ENTRY CAP REACHED — Maximum of 12 entries per participant. No exceptions.');
    return;
  }
  const toAdd = Math.min(count, remaining);
  if(toAdd <= 0){
    showAlert('bAlert','err','🚫 ENTRY CAP REACHED — Maximum of 12 entries per participant. No exceptions.');
    return;
  }

  for(let i=0;i<toAdd;i++){
    D.entries.push({
      id: Date.now()+i, name, email, order, payment,
      entryNum: existCount+i+1,
      picks:{...picks}, score:0,
      at: new Date().toISOString()
    });
  }

  save(D);
  updatePotDisplay();
  renderLB();
  showAlert('bAlert','ok',`🏀 Bracket submitted! Good luck ${name}! (${toAdd} entr${toAdd===1?'y':'ies'} added)`);
  document.getElementById('eName').value='';
  document.getElementById('eEmail').value='';
  document.getElementById('eOrder').value='';
  renderBracket();
}

// ═══════════════════════════════
// SCORING
// ═══════════════════════════════

function scoreEntry(e){
  let s=0;
  const keys=['east_g1','east_g2','west_g1','west_g2','south_g1','south_g2','midwest_g1','midwest_g2','e8_east','e8_west','e8_south','e8_midwest','ff_1','ff_2','champion'];
  keys.forEach(k=>{ if(D.results[k]&&e.picks[k]&&D.results[k]===e.picks[k]) s++; });
  return s;
}

// ═══════════════════════════════
// LEADERBOARD
// ═══════════════════════════════

function renderLB(){
  const scored = D.entries.map(e=>({...e,score:scoreEntry(e)})).sort((a,b)=>b.score-a.score);
  document.getElementById('entCt').textContent = `${D.entries.length} BRACKET${D.entries.length!==1?'S':''} SUBMITTED`;
  if(!scored.length){ document.getElementById('lbContent').innerHTML='<div class="empty">No brackets yet — be first! 🏀</div>'; return; }
  const pot=D.pot;
  let html=`<table class="lb-table"><tr><th>RANK</th><th>NAME</th><th>CORRECT</th><th>PRIZE</th><th>PAYOUT TO</th></tr>`;
  scored.forEach((e,i)=>{
    const r=i+1;
    const medal=r===1?'🥇':r===2?'🥈':r===3?'🥉':r;
    let prize='';
    if(r===1&&pot>0) prize=`<span class="prize-tag pt-1">$${Math.floor(pot*.7).toLocaleString()}</span>`;
    else if(r===2&&pot>0) prize=`<span class="prize-tag pt-2">$${Math.floor(pot*.2).toLocaleString()}</span>`;
    else if(r===3&&pot>0) prize=`<span class="prize-tag pt-3">$${Math.floor(pot*.1).toLocaleString()}</span>`;
    const payout = r<=3 ? `<span style="font-family:'Righteous',cursive;font-size:13px;color:rgba(255,255,255,.5);">${e.payment||'—'}</span>` : '';
    html+=`<tr class="rank-${r<=3?r:''}"><td><span class="rank-badge">${medal}</span></td><td>${e.name}</td><td style="font-family:'Lilita One',cursive;font-size:22px;color:var(--t);">${e.score}</td><td>${prize}</td><td>${payout}</td></tr>`;
  });
  html+='</table>';
  document.getElementById('lbContent').innerHTML=html;
}

// ═══════════════════════════════
// POT
// ═══════════════════════════════

function updatePotDisplay(){
  const p=D.pot;
  document.getElementById('potNum').textContent='$'+p.toLocaleString();
  document.getElementById('p1').textContent='$'+Math.floor(p*.7).toLocaleString();
  document.getElementById('p2').textContent='$'+Math.floor(p*.2).toLocaleString();
  document.getElementById('p3').textContent='$'+Math.floor(p*.1).toLocaleString();
}

// ═══════════════════════════════
// LIVE SCORES
// ═══════════════════════════════

async function fetchLive(){
  const c=document.getElementById('liveContent');
  try{
    const res=await fetch('https://site.api.espn.com/apis/site/v2/sports/basketball/mens-college-basketball/scoreboard?groups=100&limit=64');
    const json=await res.json();
    const events=json.events||[];
    if(!events.length){c.innerHTML='<div class="empty">No games right now. Check back during tournament rounds! 🏀</div>';return;}
    let html='';
    events.forEach(ev=>{
      const comp=ev.competitions[0];
      const st=ev.status.type;
      const home=comp.competitors.find(t=>t.homeAway==='home');
      const away=comp.competitors.find(t=>t.homeAway==='away');
      let badge='';
      if(st.name==='STATUS_IN_PROGRESS') badge='<span class="game-status s-live">🔴 LIVE</span>';
      else if(st.completed) badge='<span class="game-status s-final">FINAL</span>';
      else badge=`<span class="game-status s-soon">${st.shortDetail||'UPCOMING'}</span>`;
      html+=`
        <div class="game-card">
          <div class="game-teams">
            <div class="game-team ${away?.winner?'win':''}">
              <span class="g-seed">${away?.curatedRank?.current||''}</span>
              <span style="flex:1">${away?.team?.displayName||'TBD'}</span>
              <span class="g-score">${away?.score||''}</span>
            </div>
            <div class="game-team ${home?.winner?'win':''}">
              <span class="g-seed">${home?.curatedRank?.current||''}</span>
              <span style="flex:1">${home?.team?.displayName||'TBD'}</span>
              <span class="g-score">${home?.score||''}</span>
            </div>
          </div>
          ${badge}
        </div>`;
    });
    c.innerHTML=html;
  }catch(e){c.innerHTML='<div class="empty">Live scores unavailable right now.<br>Check back soon! 🏀</div>';}
}

