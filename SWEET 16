function renderAdminGames(){
  const regions=['east','west','south','midwest'];
  let html='';
  regions.forEach(r=>{
    const t=D.teams[r];
    [0,1].forEach(gi=>{
      const key=`${r}_g${gi+1}`;
      const pair=gi===0?[t[0],t[1]]:[t[2],t[3]];
      const cur=D.results[key]||'';
      html+=`<div class="admin-game-row">
        <div class="admin-game-lbl">${r.toUpperCase()} Game ${gi+1}<br><span style="font-size:11px;color:rgba(255,255,255,.35)">${pair[0].n} vs ${pair[1].n}</span></div>
        <select class="admin-sel" id="ag_${key}">
          <option value="">No result</option>
          <option value="${pair[0].n}" ${cur===pair[0].n?'selected':''}>(${pair[0].s}) ${pair[0].n}</option>
          <option value="${pair[1].n}" ${cur===pair[1].n?'selected':''}>(${pair[1].s}) ${pair[1].n}</option>
        </select>
        <button class="set-btn" onclick="setResult('${key}')">✓ SET</button>
      </div>`;
    });
  });
  // E8
  html+='<div style="margin:16px 0 10px;font-family:\'Titan One\',cursive;font-size:14px;color:var(--y);letter-spacing:3px;">ELITE 8</div>';
  regions.forEach(r=>{
    const key=`e8_${r}`;const cur=D.results[key]||'';
    html+=`<div class="admin-game-row">
      <div class="admin-game-lbl">Elite 8 — ${r.toUpperCase()}</div>
      <select class="admin-sel" id="ag_${key}">
        <option value="">No result</option>
        ${D.teams[r].map(t=>`<option value="${t.n}" ${cur===t.n?'selected':''}>(${t.s}) ${t.n}</option>`).join('')}
      </select>
      <button class="set-btn" onclick="setResult('${key}')">✓ SET</button>
    </div>`;
  });
  // FF
  html+='<div style="margin:16px 0 10px;font-family:\'Titan One\',cursive;font-size:14px;color:var(--t);letter-spacing:3px;">FINAL FOUR</div>';
  const allT=[...D.teams.east,...D.teams.west,...D.teams.south,...D.teams.midwest];
  ['ff_1','ff_2'].forEach((key,i)=>{
    const cur=D.results[key]||'';
    html+=`<div class="admin-game-row">
      <div class="admin-game-lbl">Final Four Game ${i+1}</div>
      <select class="admin-sel" id="ag_${key}">
        <option value="">No result</option>
        ${allT.map(t=>`<option value="${t.n}" ${cur===t.n?'selected':''}>(${t.s}) ${t.n}</option>`).join('')}
      </select>
      <button class="set-btn" onclick="setResult('${key}')">✓ SET</button>
    </div>`;
  });
  // Champion
  html+='<div style="margin:16px 0 10px;font-family:\'Titan One\',cursive;font-size:14px;color:var(--y);letter-spacing:3px;">🏆 CHAMPION</div>';
  const cc=D.results.champion||'';
  html+=`<div class="admin-game-row" style="border:1px solid rgba(255,215,0,.3);background:rgba(255,215,0,.04);">
    <div class="admin-game-lbl" style="color:var(--y);">National Champion</div>
    <select class="admin-sel" id="ag_champion" style="border-color:rgba(255,215,0,.4);color:var(--y);">
      <option value="">No result</option>
      ${allT.map(t=>`<option value="${t.n}" ${cc===t.n?'selected':''}>(${t.s}) ${t.n}</option>`).join('')}
    </select>
    <button class="set-btn" onclick="setResult('champion')" style="background:var(--y);">✓ SET</button>
  </div>`;
  document.getElementById('aGames').innerHTML=html;
}

function setResult(key){
  const el=document.getElementById('ag_'+key);
  if(el){ D.results[key]=el.value||null; save(D); alert('✓ Result saved!'); }
}

function renderAdminTeams(){
  const regions=['east','west','south','midwest'];
  let html='';
  regions.forEach(r=>{
    html+=`<div style="margin-bottom:16px;">
      <div style="font-family:'Righteous',cursive;font-size:12px;color:rgba(255,255,255,.4);letter-spacing:4px;margin-bottom:8px;">${r.toUpperCase()} REGION</div>`;
    D.teams[r].forEach((t,i)=>{
      html+=`<div style="display:flex;gap:8px;margin-bottom:6px;align-items:center;">
        <input type="number" value="${t.s}" id="ts_${r}_${i}" style="width:58px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:8px;color:#fff;font-family:'Fredoka One',cursive;font-size:14px;outline:none;" placeholder="Seed">
        <input type="text" value="${t.n}" id="tn_${r}_${i}" placeholder="Team Name" style="flex:1;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:8px 12px;color:#fff;font-family:'Fredoka One',cursive;font-size:14px;outline:none;">
      </div>`;
    });
    html+='</div>';
  });
  document.getElementById('aTeams').innerHTML=html;
}

function doSaveTeams(){
  const regions=['east','west','south','midwest'];
  regions.forEach(r=>{
    D.teams[r]=[0,1,2,3].map(i=>({
      s:parseInt(document.getElementById(`ts_${r}_${i}`).value)||0,
      n:document.getElementById(`tn_${r}_${i}`).value.trim()||'TBD'
    }));
  });
  save(D);
  renderBracket();
  renderAdminGames();
  renderAdminTeams();
  alert('✓ Teams saved! Bracket is updated and live.');
}

// ═══════════════════════════════
// TABS & UTILS
// ═══════════════════════════════

function showTab(name,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='live') fetchLive();
  if(name==='leaderboard') renderLB();
}

function showAlert(id,type,msg){
  const el=document.getElementById(id);
  el.className=`alert ${type} show`;
  el.textContent=msg;
  setTimeout(()=>el.classList.remove('show'),5000);
}

// ═══════════════════════════════
// INIT
// ═══════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  updatePotDisplay();
  renderBracket();
  renderLB();
  setInterval(()=>{ if(document.getElementById('tab-live').classList.contains('active')) fetchLive(); },60000);
});
</script>
</body>
</html>