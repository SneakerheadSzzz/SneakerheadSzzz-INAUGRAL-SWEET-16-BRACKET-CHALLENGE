<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SneakerheadSzzz – Sweet 16 Bracket Challenge</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Lilita+One&family=Righteous&family=Titan+One&display=swap" rel="stylesheet">
<style>
  :root {
    --r:#E8001D;--o:#FF6B00;--y:#FFD700;
    --g:#4CAF50;--t:#00BCD4;--b:#2196F3;--p:#9C27B0;
    --card:#0d0d0d;--border:rgba(255,255,255,0.08);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{background:#000;color:#fff;font-family:'Fredoka One',cursive;min-height:100vh;}

  /* ═══ HEADER ═══ */
  .header{background:linear-gradient(180deg,#1a0800,#000);padding:36px 20px 26px;text-align:center;border-bottom:4px solid var(--o);position:relative;overflow:hidden;}
  .header::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,var(--o) 2px,transparent 2px),radial-gradient(circle,var(--y) 2px,transparent 2px),radial-gradient(circle,var(--t) 2px,transparent 2px);background-size:120px 130px,150px 140px,110px 120px;background-position:20px 20px,60px 70px,100px 30px;opacity:0.07;}
  .logo-txt{font-family:'Lilita One',cursive;font-size:clamp(28px,6vw,68px);line-height:0.9;position:relative;z-index:1;}
  .Lr{color:var(--r)}.Lo{color:var(--o)}.Ly{color:var(--y)}.Lg{color:var(--g)}.Lt{color:var(--t)}.Lb{color:var(--b)}.Lp{color:var(--p)}
  .header-sub{font-family:'Righteous',cursive;font-size:clamp(11px,2vw,18px);color:rgba(255,255,255,0.35);letter-spacing:8px;margin-top:6px;position:relative;z-index:1;}
  .rainbow-bar{height:5px;background:linear-gradient(90deg,var(--r),var(--o),var(--y),var(--g),var(--t),var(--b),var(--p));margin:14px auto 0;border-radius:3px;max-width:560px;position:relative;z-index:1;}
  .contest-ttl{font-family:'Titan One',cursive;font-size:clamp(14px,3vw,30px);color:var(--y);letter-spacing:2px;margin-top:14px;position:relative;z-index:1;}

  /* ═══ POT ═══ */
  .pot-wrap{background:linear-gradient(135deg,rgba(255,107,0,.14),rgba(255,215,0,.08));border:2px solid rgba(255,107,0,.38);border-radius:16px;padding:18px 28px;text-align:center;margin:18px auto;max-width:460px;}
  .pot-lbl{font-family:'Righteous',cursive;font-size:14px;color:rgba(255,255,255,.42);letter-spacing:6px;}
  .pot-num{font-family:'Lilita One',cursive;font-size:clamp(36px,7vw,68px);color:var(--y);line-height:1;filter:drop-shadow(0 0 18px rgba(255,215,0,.35));}
  .pot-split{display:flex;justify-content:center;gap:18px;margin-top:8px;flex-wrap:wrap;}
  .pot-place{font-family:'Righteous',cursive;font-size:13px;color:rgba(255,255,255,.5);}
  .pot-place span{color:var(--y);}

  /* ═══ TABS ═══ */
  .tabs{display:flex;justify-content:center;gap:8px;padding:18px 16px;flex-wrap:wrap;}
  .tab-btn{font-family:'Fredoka One',cursive;font-size:16px;padding:10px 20px;border-radius:30px;border:2px solid rgba(255,255,255,.15);background:rgba(255,255,255,.04);color:rgba(255,255,255,.55);cursor:pointer;transition:all .2s;}
  .tab-btn.active{background:var(--o);border-color:var(--o);color:#000;}
  .tab-btn:hover:not(.active){border-color:var(--o);color:#fff;}

  /* ═══ SECTIONS ═══ */
  .section{display:none;padding:0 14px 50px;max-width:860px;margin:0 auto;}
  .section.active{display:block;}

  /* ═══ CARDS ═══ */
  .card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:18px;}
  .card-title{font-family:'Titan One',cursive;font-size:20px;color:var(--o);letter-spacing:2px;margin-bottom:18px;}
  .form-row{display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;}
  .form-grp{flex:1;min-width:190px;}
  .form-grp label{display:block;font-family:'Righteous',cursive;font-size:12px;color:rgba(255,255,255,.45);letter-spacing:2px;margin-bottom:6px;}
  .form-grp input,.form-grp select{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:11px 14px;color:#fff;font-family:'Fredoka One',cursive;font-size:15px;outline:none;transition:border-color .2s;}
  .form-grp input:focus,.form-grp select:focus{border-color:var(--o);}
  .form-grp select option{background:#111;}

  /* ═══ LOGO RADIO BUTTONS ═══ */
  .matchup-block{background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:12px;}
  .matchup-lbl{font-family:'Righteous',cursive;font-size:11px;color:rgba(255,255,255,.25);letter-spacing:3px;margin-bottom:12px;}
  .team-options{display:flex;flex-direction:column;gap:8px;}

  .team-radio{display:flex;align-items:center;gap:12px;cursor:pointer;padding:11px 14px;border-radius:12px;border:2px solid rgba(255,255,255,.07);background:rgba(255,255,255,.025);transition:all .18s;user-select:none;position:relative;}
  .team-radio:hover{border-color:rgba(255,107,0,.35);background:rgba(255,107,0,.05);}
  .team-radio.picked{border-color:var(--o);background:rgba(255,107,0,.11);box-shadow:0 0 14px rgba(255,107,0,.18);}
  .team-radio input[type=radio]{position:absolute;opacity:0;width:0;height:0;}

  /* SHSzzz logo radio indicator */
  .shz-dot{width:34px;height:34px;border-radius:50%;border:2px solid rgba(255,255,255,.18);background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .18s;}
  .shz-dot-s{font-family:'Lilita One',cursive;font-size:15px;color:rgba(255,255,255,.2);transition:all .18s;line-height:1;}
  .team-radio.picked .shz-dot{border-color:var(--o);background:rgba(255,107,0,.22);box-shadow:0 0 10px rgba(255,107,0,.4);}
  .team-radio.picked .shz-dot-s{color:var(--o);text-shadow:0 0 8px rgba(255,107,0,.7);}

  .team-nm{font-family:'Fredoka One',cursive;font-size:17px;color:rgba(255,255,255,.65);flex:1;transition:color .18s;}
  .team-radio.picked .team-nm{color:#fff;}
  .seed-tag{font-family:'Righteous',cursive;font-size:10px;color:rgba(255,255,255,.3);background:rgba(255,255,255,.06);padding:3px 8px;border-radius:10px;letter-spacing:1px;flex-shrink:0;transition:all .18s;}
  .team-radio.picked .seed-tag{background:rgba(255,107,0,.2);color:var(--o);}

  .vs-row{display:flex;align-items:center;gap:10px;margin:4px 0;}
  .vs-row::before,.vs-row::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.05);}
  .vs-row span{font-family:'Righteous',cursive;font-size:10px;color:rgba(255,255,255,.2);letter-spacing:3px;}

  /* ═══ REGION LABELS ═══ */
  .region-lbl{display:inline-block;font-family:'Lilita One',cursive;font-size:14px;letter-spacing:4px;padding:6px 16px;border-radius:20px;margin-bottom:10px;}
  .rl-e{background:rgba(232,0,29,.18);color:var(--r);border:1px solid var(--r);}
  .rl-w{background:rgba(33,150,243,.18);color:var(--b);border:1px solid var(--b);}
  .rl-s{background:rgba(76,175,80,.18);color:var(--g);border:1px solid var(--g);}
  .rl-m{background:rgba(255,215,0,.12);color:var(--y);border:1px solid var(--y);}

  .round-ttl{font-family:'Titan One',cursive;font-size:18px;color:var(--t);letter-spacing:3px;margin:22px 0 12px;padding-bottom:8px;border-bottom:2px solid rgba(0,188,212,.25);}

  /* Champion */
  .champ-block{background:rgba(255,215,0,.06);border:1px solid rgba(255,215,0,.28);border-radius:14px;padding:20px;margin-bottom:12px;}
  .champ-lbl{font-family:'Titan One',cursive;font-size:18px;color:var(--y);letter-spacing:2px;margin-bottom:14px;}
  .champ-sel{width:100%;background:rgba(255,215,0,.08);border:2px solid rgba(255,215,0,.35);border-radius:12px;padding:14px 16px;color:var(--y);font-family:'Fredoka One',cursive;font-size:18px;outline:none;cursor:pointer;}
  .champ-sel option{background:#111;color:#fff;}

  /* ═══ LOGO SUBMIT BUTTON ═══ */
  .shz-sub-btn{width:100%;border:none;border-radius:16px;padding:0;background:linear-gradient(135deg,var(--r),var(--o),var(--y),var(--g),var(--t));cursor:pointer;margin-top:22px;box-shadow:0 6px 28px rgba(255,107,0,.4);transition:transform .12s,box-shadow .2s;position:relative;overflow:hidden;}
  .shz-sub-btn:hover{transform:translateY(-3px);box-shadow:0 10px 40px rgba(255,107,0,.6);}
  .shz-sub-btn:active{transform:translateY(0);}
  .shz-sub-inner{display:flex;align-items:center;justify-content:center;gap:16px;padding:20px 28px;background:linear-gradient(135deg,rgba(0,0,0,.3),rgba(0,0,0,.1));border-radius:16px;}
  .shz-sub-logo{font-family:'Lilita One',cursive;font-size:26px;line-height:1;-webkit-text-stroke:1px rgba(0,0,0,.4);}
  .shz-sub-txt{font-family:'Titan One',cursive;font-size:22px;color:#fff;letter-spacing:4px;text-shadow:0 2px 8px rgba(0,0,0,.5);}

  /* Admin enter btn */
  .shz-admin-btn{width:100%;border:none;border-radius:12px;padding:0;background:linear-gradient(135deg,var(--o),var(--r));cursor:pointer;box-shadow:0 4px 18px rgba(255,107,0,.35);transition:transform .12s;}
  .shz-admin-btn:hover{transform:translateY(-2px);}
  .shz-admin-inner{display:flex;align-items:center;justify-content:center;gap:12px;padding:16px 24px;background:rgba(0,0,0,.2);border-radius:12px;}
  .shz-admin-logo{font-family:'Lilita One',cursive;font-size:22px;color:var(--y);}
  .shz-admin-txt{font-family:'Titan One',cursive;font-size:20px;color:#fff;letter-spacing:3px;}

  /* ═══ LEADERBOARD ═══ */
  .lb-table{width:100%;border-collapse:collapse;margin-top:14px;}
  .lb-table th{font-family:'Righteous',cursive;font-size:12px;letter-spacing:3px;color:rgba(255,255,255,.35);padding:10px 14px;text-align:left;border-bottom:1px solid rgba(255,255,255,.07);}
  .lb-table td{padding:14px;border-bottom:1px solid rgba(255,255,255,.04);font-size:16px;}
  .rank-1 td{background:rgba(255,215,0,.06);}
  .rank-2 td{background:rgba(192,192,192,.04);}
  .rank-3 td{background:rgba(205,127,50,.04);}
  .rank-badge{font-family:'Lilita One',cursive;font-size:22px;}
  .rank-1 .rank-badge{color:var(--y);}
  .rank-2 .rank-badge{color:#C0C0C0;}
  .rank-3 .rank-badge{color:#CD7F32;}
  .prize-tag{font-size:12px;font-family:'Righteous',cursive;letter-spacing:2px;padding:4px 10px;border-radius:20px;}
  .pt-1{background:rgba(255,215,0,.15);color:var(--y);}
  .pt-2{background:rgba(192,192,192,.15);color:#C0C0C0;}
  .pt-3{background:rgba(205,127,50,.15);color:#CD7F32;}

  /* ═══ LIVE GAMES ═══ */
  .game-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 18px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
  .game-status{font-family:'Righteous',cursive;font-size:11px;letter-spacing:2px;padding:4px 10px;border-radius:20px;}
  .s-live{background:rgba(232,0,29,.2);color:var(--r);animation:blink 1.5s infinite;}
  .s-final{background:rgba(255,255,255,.07);color:rgba(255,255,255,.45);}
  .s-soon{background:rgba(0,188,212,.14);color:var(--t);}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
  .game-teams{flex:1;min-width:200px;}
  .game-team{display:flex;align-items:center;justify-content:space-between;padding:4px 0;font-size:15px;}
  .game-team.win{color:var(--y);}
  .g-score{font-family:'Lilita One',cursive;font-size:22px;min-width:34px;text-align:right;}
  .g-seed{font-size:10px;color:rgba(255,255,255,.35);font-family:'Righteous',cursive;min-width:22px;}

  /* ═══ ADMIN ═══ */
  .admin-login-wrap{background:var(--card);border:1px solid rgba(255,107,0,.3);border-radius:16px;padding:28px;max-width:380px;margin:0 auto;text-align:center;}
  .admin-ttl{font-family:'Titan One',cursive;font-size:22px;color:var(--o);margin-bottom:20px;letter-spacing:2px;}
  .admin-input{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(255,107,0,.3);border-radius:10px;padding:14px;color:#fff;font-family:'Fredoka One',cursive;font-size:18px;text-align:center;outline:none;margin-bottom:14px;letter-spacing:4px;}
  .admin-panel{display:none;}
  .admin-panel.on{display:block;}
  .admin-game-row{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:10px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
  .admin-game-lbl{flex:1;min-width:160px;font-size:14px;color:rgba(255,255,255,.75);}
  .admin-sel{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:8px;padding:8px 12px;color:#fff;font-family:'Fredoka One',cursive;font-size:14px;outline:none;cursor:pointer;min-width:150px;}
  .admin-sel option{background:#111;}
  .set-btn{background:var(--g);border:none;border-radius:8px;padding:9px 18px;font-family:'Fredoka One',cursive;font-size:14px;color:#000;cursor:pointer;letter-spacing:1px;}
  .recalc-btn{width:100%;background:linear-gradient(135deg,var(--t),var(--b));border:none;border-radius:12px;padding:15px;font-family:'Titan One',cursive;font-size:18px;color:#fff;cursor:pointer;letter-spacing:3px;margin-top:18px;box-shadow:0 4px 20px rgba(0,188,212,.3);}
  .pot-input{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);border-radius:10px;padding:12px 14px;color:#fff;font-family:'Fredoka One',cursive;font-size:18px;outline:none;}
  .update-pot-btn{background:var(--o);border:none;border-radius:10px;padding:12px 24px;font-family:'Fredoka One',cursive;font-size:16px;color:#000;cursor:pointer;margin-top:10px;letter-spacing:1px;}

  /* ═══ RULES ═══ */
  .rules-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:26px;margin-bottom:18px;}
  .rules-ttl{font-family:'Titan One',cursive;font-size:20px;color:var(--o);letter-spacing:2px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid rgba(255,107,0,.25);}
  .rules-txt{font-family:'Righteous',cursive;font-size:15px;line-height:1.75;color:rgba(255,255,255,.72);letter-spacing:.4px;}
  .rules-txt strong{color:#fff;}
  .hl{color:var(--y);}
  .pay-table{width:100%;border-collapse:collapse;margin:14px 0;}
  .pay-table th{background:rgba(255,107,0,.14);color:var(--o);font-family:'Righteous',cursive;letter-spacing:2px;padding:10px 14px;text-align:left;font-size:12px;}
  .pay-table td{padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.05);font-family:'Righteous',cursive;font-size:14px;color:rgba(255,255,255,.75);}
  .pay-table td strong{color:var(--y);font-size:17px;}

  /* ═══ MISC ═══ */
  .sec-hdr{font-family:'Titan One',cursive;font-size:20px;letter-spacing:3px;color:var(--o);margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid rgba(255,107,0,.28);}
  .empty{text-align:center;padding:36px 20px;color:rgba(255,255,255,.28);font-family:'Righteous',cursive;font-size:16px;letter-spacing:2px;}
  .spinner{text-align:center;padding:28px;color:var(--t);font-family:'Righteous',cursive;letter-spacing:3px;animation:blink 1s infinite;}
  .alert{padding:14px 18px;border-radius:12px;margin-bottom:14px;font-size:15px;display:none;}
  .alert.ok{background:rgba(76,175,80,.15);border:1px solid rgba(76,175,80,.4);color:var(--g);}
  .alert.err{background:rgba(232,0,29,.15);border:1px solid rgba(232,0,29,.4);color:var(--r);}
  .alert.show{display:block;}
  .entry-ct{font-family:'Righteous',cursive;font-size:13px;color:rgba(255,255,255,.35);letter-spacing:3px;margin-bottom:14px;}
  .footer{text-align:center;padding:28px 20px;border-top:1px solid rgba(255,255,255,.05);font-family:'Righteous',cursive;font-size:12px;color:rgba(255,255,255,.22);letter-spacing:3px;}
  @media(max-width:500px){.shz-sub-logo{font-size:18px;}.shz-sub-txt{font-size:16px;}}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="logo-txt">
    <span class="Lr">S</span><span class="Lo">neak</span><span class="Ly">er</span><span class="Lg">hea</span><span class="Lt">d</span><span class="Lp">S</span><span class="Lr">z</span><span class="Lo">z</span><span class="Ly">z</span><span class="Lg">!</span>
  </div>
  <div class="header-sub">BY ZNK</div>
  <div class="rainbow-bar"></div>
  <div class="contest-ttl">🏀 INAUGURAL SWEET 16 BRACKET CHALLENGE 🏀</div>
  <div class="pot-wrap">
    <div class="pot-lbl">CURRENT POT</div>
    <div class="pot-num" id="potNum">$0</div>
    <div class="pot-split">
      <div class="pot-place">🥇 1st: <span id="p1">$0</span></div>
      <div class="pot-place">🥈 2nd: <span id="p2">$0</span></div>
      <div class="pot-place">🥉 3rd: <span id="p3">$0</span></div>
    </div>
  </div>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn active" onclick="showTab('bracket',this)">🏀 My Bracket</button>
  <button class="tab-btn" onclick="showTab('leaderboard',this)">🏆 Leaderboard</button>
  <button class="tab-btn" onclick="showTab('live',this)">📺 Live Scores</button>
  <button class="tab-btn" onclick="showTab('rules',this)">📋 Rules</button>
  <button class="tab-btn" onclick="showTab('admin',this)">🔒 Admin</button>
</div>

<!-- ═══════════ MY BRACKET ═══════════ -->
<div class="section active" id="tab-bracket">
  <div id="bAlert" class="alert"></div>

  <div class="card">
    <div class="card-title">YOUR INFO</div>
    <div class="form-row">
      <div class="form-grp"><label>FULL NAME</label><input type="text" id="eName" placeholder="Your name"></div>
      <div class="form-grp"><label>EMAIL</label><input type="email" id="eEmail" placeholder="your@email.com"></div>
    </div>
    <div class="form-row">
      <div class="form-grp"><label>ORDER / CONFIRMATION #</label><input type="text" id="eOrder" placeholder="From your SneakerheadSzzz.com purchase"></div>
      <div class="form-grp"><label>VENMO / PAYPAL / APPLE CASH / ZELLE</label><input type="text" id="ePayment" placeholder="Your handle or email (for prize payout)"></div>
    </div>
    <div class="form-row">
      <div class="form-grp">
        <label>ENTRIES PURCHASED</label>
        <select id="eCount">
          <option value="1">1 Entry — $3</option>
          <option value="3">3 Entries — $9</option>
          <option value="5">5 Entries — $19</option>
          <option value="7">7 Entries — $29</option>
          <option value="10">10 Entries — $44</option>
          <option value="12">12 Entries — MAX CAP</option>
        </select>
      </div>
    </div>
  </div>

  <!-- SWEET 16 -->
  <div class="card">
    <div class="card-title">SWEET 16 PICKS</div>
    <p style="font-family:'Righteous',cursive;font-size:13px;color:rgba(255,255,255,.38);letter-spacing:1px;margin-bottom:20px;">Teams updated Sunday. Pick the winner of each matchup.</p>

    <div class="region-lbl rl-e">EAST</div>
    <div id="east-r"></div>

    <div class="region-lbl rl-w" style="margin-top:14px;">WEST</div>
    <div id="west-r"></div>

    <div class="region-lbl rl-s" style="margin-top:14px;">SOUTH</div>
    <div id="south-r"></div>

    <div class="region-lbl rl-m" style="margin-top:14px;">MIDWEST</div>
    <div id="midwest-r"></div>

    <div class="round-ttl">ELITE 8 PICKS</div>
    <div id="e8-r"></div>

    <div class="round-ttl">FINAL FOUR PICKS</div>
    <div id="ff-r"></div>

    <div class="round-ttl">🏆 NATIONAL CHAMPION</div>
    <div id="champ-r"></div>
  </div>

  <!-- LOGO SUBMIT BUTTON -->
  <button class="shz-sub-btn" onclick="submitBracket()">
    <div class="shz-sub-inner">
      <div class="shz-dot" style="width:44px;height:44px;border-color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.1);">
        <span class="shz-dot-s" style="font-size:22px;color:#fff;">S</span>
      </div>
      <div class="shz-sub-txt">SUBMIT MY BRACKET</div>
      <div class="shz-dot" style="width:44px;height:44px;border-color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.1);">
        <span class="shz-dot-s" style="font-size:22px;color:#fff;">S</span>
      </div>
    </div>
  </button>
</div>

<!-- ═══════════ LEADERBOARD ═══════════ -->
<div class="section" id="tab-leaderboard">
